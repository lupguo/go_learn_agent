# ========================================
# Provider 选择 (默认 anthropic)
# ========================================
PROVIDER_TYPE=openai
# 可选值: anthropic, openai, gemini

# ========================================
# 模型 ID (必填)
# ========================================
MODEL_ID=gpt-5.4-nano

# ========================================
# Anthropic 配置
# ========================================
# API Key (ANTHROPIC_API_KEY 优先于 API_KEY)
ANTHROPIC_API_KEY=sk-ant-xxx
# Base URL (可选，用于兼容 API 代理)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Anthropic 兼容提供商 ---
# MiniMax:   ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic   MODEL_ID=MiniMax-M2.5
# GLM:       ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic     MODEL_ID=glm-5
# Kimi:      ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic   MODEL_ID=kimi-k2.5
# DeepSeek:  ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic  MODEL_ID=deepseek-chat

# ========================================
# OpenAI 配置
# ========================================
# PROVIDER_TYPE=openai
# OPENAI_API_KEY=sk-xxx
# MODEL_ID=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com

# ========================================
# Gemini 配置
# ========================================
# PROVIDER_TYPE=gemini
# GEMINI_API_KEY=AIza-xxx
# MODEL_ID=gemini-2.0-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ========================================
# 通用 (各 Provider 专有 Key 优先于此)
# ========================================
# API_KEY=xxx
# BASE_URL=https://my-proxy.example.com
